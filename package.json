		"test-data",
		"profiles",
		"companies",
		"seed-data",
		"typescript",
		"types",
		"developer-tools"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/gusdeboer/random-profiles-types.git"
	},
	"homepage": "https://random-profiles.com",
	"bugs": {
		"url": "https://github.com/gusdeboer/random-profiles-types/issues"
	},
	"devDependencies": {
		"typescript": "^5.4.0"
	}
}
